---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = 'Причинили',
  description = 'Из чата — в очерк. Медиа, где живые споры НКО-сектора превращаются в литературные очерки и деловой разбор.',
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Yandex.Metrika counter -->
  <script type="text/javascript" is:inline>
    (function(m,e,t,r,i,k,a){
      m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {
        if (document.scripts[j].src === r) { return; }
      }
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a);
    })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=107451279', 'ym');

    ym(107451279, 'init', {
      clickmap: true,
      trackLinks: true,
      accurateTrackBounce: true,
      webvisor: true
    });
  </script>
  <!-- /Yandex.Metrika counter -->
</head>
<body class={bodyClass}>
  <noscript><div><img src="https://mc.yandex.ru/watch/107451279" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
  <div class="shell">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</body>
</html>
