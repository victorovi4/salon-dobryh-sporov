---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

const others = (await getCollection('essays'))
  .filter(e => e.data.topic === essay.data.topic && e.id !== essay.id)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
const topic = (await getCollection('topics')).find(t => t.id === essay.data.topic);
const siteUrl = 'https://prichinili.ru';
const essayUrl = `${siteUrl}/essays/${essay.id}/`;
const shareUrl = `https://t.me/share/url?url=${encodeURIComponent(essayUrl)}&text=${encodeURIComponent(`«${essay.data.title}» — Причинили`)}`;

const dateStr = essay.data.date.toLocaleDateString('ru-RU', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<Base title={`${essay.data.title} — Причинили`} description={essay.data.excerpt} bodyClass="essay-page">
  <article class="prose">
    <header class="essay-head">
      <div class="style-tag">{essay.data.styleLabel}</div>
      <h1>{essay.data.title}</h1>
      <p class="desc">{essay.data.excerpt}</p>
      <div class="date">{dateStr}</div>
      {essay.data.audioUrl && (
        <div class="audio-card" aria-label="Аудиоверсия очерка">
          <div class="audio-card__label">Аудиоверсия</div>
          <audio controls preload="metadata" src={essay.data.audioUrl}></audio>
          {essay.data.durationSec && (
            <div class="audio-card__meta">
              Длительность: {Math.floor(essay.data.durationSec / 60)}:{String(essay.data.durationSec % 60).padStart(2, '0')}
            </div>
          )}
        </div>
      )}
    </header>

    <Content />

    <nav class="essay-actions" aria-label="Навигация по очерку">
      {topic && <a href={`/topics/${topic.id}/`}>← К выпуску «{topic.data.title}»</a>}
      <a href={shareUrl} target="_blank" rel="noopener">Поделиться в Telegram →</a>
      <a href="/essays/">Все очерки →</a>
    </nav>
  </article>

  {others.length > 0 && (
    <section class="other-voices">
      <h2>Другие голоса этой темы</h2>
      <div class="grid">
        {others.map(o => (
          <a class="card" href={`/essays/${o.id}/`}>
            <div class="style-tag">{o.data.styleLabel}</div>
            <h3>{o.data.title}</h3>
            <p class="excerpt">{o.data.excerpt}</p>
            <div class="meta"><span class="more">Читать →</span></div>
          </a>
        ))}
      </div>
    </section>
  )}
</Base>
