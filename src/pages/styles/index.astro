---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const styles = (await getCollection('styles')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base title="Авторские оптики — Причинили" description="Как разные литературные голоса читают один и тот же лог чата.">
  <div class="page-head">
    <h1>Авторские оптики</h1>
    <p>Это не просто стилизация. Каждый голос читает один и тот же лог чата по-своему: ищет разные реплики, напряжения, паузы и смешные сбои языка.</p>
  </div>

  <section class="prose" style="max-width:860px;margin:0 auto 36px;">
    <h2>Принцип</h2>
    <p><strong>Лог — источник; разметка — навигатор; очерк — авторское чтение.</strong> Мы не даём всем голосам один синопсис. Каждый голос получает анонимизированный лог и отдельную задачу: что именно искать в живом обсуждении.</p>
  </section>

  <div class="grid">
    {styles.map(style => {
      const essays = style.data.examples;
      return (
        <article class="card">
          <div class="style-tag">Голос · {String(style.data.order).padStart(2, '0')}</div>
          <h3>{style.data.name}</h3>
          <p class="excerpt">{style.data.description}</p>

          <div class="lens-block">
            <h4>Что ищет в логе</h4>
            <p>{style.data.looksFor}</p>
          </div>

          <div class="lens-block">
            <h4>Сигналы</h4>
            <ul>
              {style.data.signals.slice(0, 5).map(signal => <li>{signal}</li>)}
            </ul>
          </div>

          <div class="lens-block">
            <h4>Конфликт</h4>
            <p>{style.data.conflict}</p>
          </div>

          <p class="excerpt" style="font-size:13px;color:var(--ink-faint);">Форма результата: {style.data.output}</p>
          <p class="excerpt" style="font-size:13px;color:var(--ink-faint);">Лучше всего для: {style.data.bestFor}</p>

          {essays.length > 0 && (
            <div class="meta">
              <span>Пример: {essays.join(', ')}</span>
            </div>
          )}
        </article>
      );
    })}
  </div>
</Base>
